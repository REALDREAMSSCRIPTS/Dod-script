-- Input de Tamanho
local sizeInput = Instance.new("TextBox")
sizeInput.Size = UDim2.new(0.9, 0, 0, 40)
sizeInput.Position = UDim2.new(0.05, 0, 0.65, 0)
sizeInput.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
sizeInput.PlaceholderText = "Tamanho da Hitbox (1-30)"
sizeInput.Text = tostring(settings.hitboxSize)
sizeInput.TextColor3 = Color3.fromRGB(255, 255, 255)
sizeInput.TextScaled = true
sizeInput.Font = Enum.Font.Gotham
sizeInput.Parent = mainFrame

sizeInput.FocusLost:Connect(function()
    local newSize = tonumber(sizeInput.Text)
    if newSize and newSize >= 1 and newSize <= 30 then
        settings.hitboxSize = newSize
        if settings.hitboxEnabled then updateHitboxes() end
    else
        sizeInput.Text = tostring(settings.hitboxSize)
    end
end)

