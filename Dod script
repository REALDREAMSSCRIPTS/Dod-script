    hitboxButton.Text = settings.hitboxEnabled and "Hitbox Inimiga: LIGADO" or "Hitbox Inimiga: DESLIGADO"
    hitboxButton.BackgroundColor3 = settings.hitboxEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60)
    updateHitboxes()
