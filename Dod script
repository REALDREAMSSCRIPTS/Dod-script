--[[
    REALDREAMSSCRIPTS - Combat Pack Otimizado
    Correções: Hitbox afeta inimigos, melhor estabilidade de loops.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

-- Configurações
local settings = {
    dieOfDeath = false,
    infiniteStamina = false,
    hitboxEnabled = false,
    hitboxSize = 5,
    hitboxTransparency = 0.5,
    hitboxColor = Color3.fromRGB(255, 0, 0)
}

-- ========== FUNÇÕES PRINCIPAIS ==========

-- God Mode Local (Prevenção ativa)
RunService.Heartbeat:Connect(function()
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and settings.dieOfDeath then
            hum.BreakJointsOnDeath = false
            if hum.Health < 20 then -- Previne chegar a 0
                hum.Health = hum.MaxHealth
            end
        end
    end
end)

-- Stamina Infinita
RunService.Heartbeat:Connect(function()
    local char = player.Character
    if char and settings.infiniteStamina then
        local stamina = char:FindFirstChild("Stamina") or char:FindFirstChild("Energy") or char:FindFirstChild("StaminaBar")
        if stamina and stamina:IsA("ValueBase") then
            stamina.Value = stamina.MaxValue or 100
        end
    end
end)

-- Hitbox Expander (Aplica nos OUTROS jogadores)
local function updateHitboxes()
    for _, enemy in ipairs(Players:GetPlayers()) do
        if enemy ~= player and enemy.Character then
            local root = enemy.Character:FindFirstChild("HumanoidRootPart")
            if root then
                if settings.hitboxEnabled then
                    -- Altera o tamanho da própria RootPart do inimigo para facilitar o hit
                    root.Size = Vector3.new(settings.hitboxSize, settings.hitboxSize, settings.hitboxSize)
                    root.Transparency = settings.hitboxTransparency
                    root.Color = settings.hitboxColor
                    root.Material = Enum.Material.Neon
                    root.CanCollide = false
                else
                    -- Reseta ao tamanho padrão do Roblox se desligado
                    root.Size = Vector3.new(2, 2, 1)
                    root.Transparency = 1
                    root.CanCollide = false
                end
            end
        end
    end
end

-- Mantém as hitboxes dos inimigos atualizadas se eles spawnarem
RunService.RenderStepped:Connect(function()
    if settings.hitboxEnabled then
        updateHitboxes()
    end
end)

